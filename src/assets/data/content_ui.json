          }
        },
        "tradingPostSell": {
          "lang-store": {
            "ja": "不要になったアイテムを売ることができます。アイテムを売りすぎて、ロケットが発射できなくならないように注意してください。",
            "en": "You can sell items you no longer need. Be careful not to sell too much and leave yourself unable to launch a rocket."
          }
        },
        "tradingPostBuy": {
          "lang-store": {
            "ja": "様々な商品が売りに出されています。セール品もありますのでお見逃しなく！",
            "en": "A variety of goods are for sale here. Some items may be discounted, so do not miss them."
          }
        },
        "repairDockIntro": {
          "lang-store": {
            "ja": "ようこそ Repair Dock へ。ここでは発射台にエネルギーを充填したり、所持しているロケットを分解して強化することができます。",
            "en": "Welcome to Repair Dock. Here you can charge launchers and dismantle owned rockets to enhance their parts."
          }
        },
        "repairDockRepair": {
          "lang-store": {
            "ja": "発射台の使用回数を回復することができます。",
            "en": "You can restore launcher charges here."
          }
        },
        "repairDockDismantle": {
          "lang-store": {
            "ja": "ロケットを分解してパーツに戻すことができます。分解したパーツは調整され、強化されます。使用するたびに価格が上がっていきますので使い過ぎに注意してください。",
            "en": "You can dismantle rockets back into parts. Dismantled parts are adjusted and enhanced. The price rises each time you use this service, so do not overuse it."
