        "blackMarketIntro": {
          "lang-store": {
            "ja": "ようこそ Black Market へ。ここでは通常では流通していない強化済みのアイテムを入手できるかもしれません。",
            "en": "Welcome to Black Market. Here you may obtain enhanced items that are not normally distributed."
          }
        },
        "blackMarketBuy": {
          "lang-store": {
            "ja": "Black Market を訪れるたびに通常取引かプレミアム取引のどちらか1つだけ購入することができます。何が獲得できるかは買ってからのお楽しみですが、強化済みの貴重なアイテムが手に入るかもしれません。",
            "en": "Each time you visit Black Market, you can buy either one standard deal or one premium deal. You will not know what you get until you buy, but you may obtain a valuable enhanced item."
          }
        },
        "blackMarketAcquired": {
          "lang-store": {
            "ja": "獲得したアイテムはこちらに表示されます。",
            "en": "Items you obtain are shown here."
          }
        },
        "blackMarketRisk": {
          "lang-store": {
            "ja": "Black Market を経由するたびに、セクターの星の数が増えていきます。増えた星をアイテム源として活用するのか、星の重力から抜け出せなくなってしまうのか。それはあなたの実力しだいです。",
            "en": "Each time you pass through Black Market, the number of stars in later sectors increases. Whether you use those stars as item sources or become trapped by their gravity is up to your skill."
          }
        }
